generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id        String          @id @default(cuid())
  name      String
  type      String          // INCOME | EXPENSE
  icon      String?
  color     String?
  isDefault Boolean         @default(false)
  parentId  String?
  parent    Category?       @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[]      @relation("SubCategories")
  createdAt DateTime        @default(now())

  transactions Transaction[]
  budgets      Budget[]
}

model PaymentMethod {
  id          String   @id @default(cuid())
  name        String
  type        String   // CREDIT_CARD | DEBIT_CARD | CASH | BANK_TRANSFER | E_WALLET
  cardCompany String?
  paymentDay  Int?
  creditLimit Int?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  transactions Transaction[]
}

model Transaction {
  id              String         @id @default(cuid())
  amount          Int
  discountAmount  Int            @default(0)
  type            String         // INCOME | EXPENSE
  description     String?
  memo            String?
  date            DateTime
  categoryId      String?
  category        Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  paymentMethodId String?
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  tags            Tag[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Budget {
  id         String    @id @default(cuid())
  amount     Int
  month      Int
  year       Int
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())

  @@unique([month, year, categoryId])
}

model RecurringTransaction {
  id              String   @id @default(cuid())
  amount          Int
  type            String   // INCOME | EXPENSE
  description     String
  frequency       String   // DAILY | WEEKLY | MONTHLY | YEARLY
  dayOfMonth      Int?
  dayOfWeek       Int?
  startDate       DateTime
  endDate         DateTime?
  isActive        Boolean  @default(true)
  categoryId      String
  paymentMethodId String?
  createdAt       DateTime @default(now())
}

model Tag {
  id           String        @id @default(cuid())
  name         String        @unique
  transactions Transaction[]
}

model Asset {
  id             String             @id @default(cuid())
  name           String
  type           String             // DEPOSIT | SAVINGS | INVESTMENT | CRYPTO | PENSION_INSURANCE
  institution    String?
  accountNumber  String?
  interestRate   Float?
  maturityDate   DateTime?
  memo           String?
  currentValue   Int                @default(0)
  initialAmount  Int                @default(0)
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  transactions   AssetTransaction[]
  snapshots      AssetSnapshot[]
}

model AssetTransaction {
  id        String   @id @default(cuid())
  assetId   String?
  asset     Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  type      String   // BUY | SELL | DEPOSIT | WITHDRAW | INTEREST | DIVIDEND
  amount    Int
  quantity  Float?
  unitPrice Float?
  date      DateTime
  memo      String?
  createdAt DateTime @default(now())
}

model AssetSnapshot {
  id        String   @id @default(cuid())
  assetId   String?
  asset     Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  value     Int
  date      DateTime
  createdAt DateTime @default(now())

  @@unique([assetId, date])
}

model FixedCost {
  id             String             @id @default(cuid())
  name           String
  expectedAmount Int
  category       String    @default("ETC")  // HOUSING | UTILITY | TELECOM | SUBSCRIPTION | INSURANCE | TRANSPORT | FINANCE | ETC
  costType       String    @default("EXPENSE")  // EXPENSE | SAVING
  dueDay         Int?
  memo           String?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  payments       FixedCostPayment[]
}

model FixedCostPayment {
  id           String    @id @default(cuid())
  fixedCostId  String?
  fixedCost    FixedCost? @relation(fields: [fixedCostId], references: [id], onDelete: SetNull)
  year         Int
  month        Int
  isPaid       Boolean   @default(false)
  actualAmount Int?
  paidAt       DateTime?
  createdAt    DateTime  @default(now())

  @@unique([fixedCostId, year, month])
}
